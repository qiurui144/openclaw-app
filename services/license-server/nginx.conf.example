# OpenClaw 授权服务 Nginx 反代配置
# 复制到 /etc/nginx/sites-available/license.conf 并修改域名
# sudo ln -s /etc/nginx/sites-available/license.conf /etc/nginx/sites-enabled/
# sudo nginx -t && sudo systemctl reload nginx

server {
    listen 80;
    server_name license.你的域名.com;

    # Let's Encrypt 验证
    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    server_name license.你的域名.com;

    ssl_certificate     /etc/letsencrypt/live/license.你的域名.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/license.你的域名.com/privkey.pem;

    # 微信回调需要接收 XML
    client_max_body_size 1m;

    location / {
        proxy_pass http://127.0.0.1:3800;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
